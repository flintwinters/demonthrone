{
  "name": "demonthrone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm run lint && node --test tests/*.test.mjs && npm run syntax",
    "lint": "eslint .",
    "syntax": "find src -maxdepth 1 -name '*.js' -print0 | xargs -0 -n1 node --check",
    "backend": "python -m backend.app",
    "serve": "npx serve .",
    "test": "npm run check"
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "eslint": "^9.31.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
